{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "composite": true,
    "resolveJsonModule": true
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/gateway" },
    { "path": "packages/agent" }
  ],
  "files": []
}
